OPENKORE_AI_APP_NAME=openkore-ai-sidecar
OPENKORE_AI_ENV=development
OPENKORE_AI_HOST=127.0.0.1
OPENKORE_AI_PORT=18081
OPENKORE_AI_LOG_LEVEL=INFO
OPENKORE_AI_LOG_JSON=1
OPENKORE_AI_ENABLE_DOCS=1
OPENKORE_AI_CONTRACT_VERSION=v1
OPENKORE_AI_ACTION_DEFAULT_TTL_SECONDS=30
OPENKORE_AI_ACTION_MAX_QUEUE_PER_BOT=128
OPENKORE_AI_SNAPSHOT_CACHE_TTL_SECONDS=120
OPENKORE_AI_TELEMETRY_MAX_PER_BOT=500
OPENKORE_AI_TELEMETRY_OPERATIONAL_WINDOW_MINUTES=60
OPENKORE_AI_TELEMETRY_RECENT_INCIDENTS_LIMIT=100
OPENKORE_AI_TELEMETRY_BACKLOG_MAX_EVENTS=10000
OPENKORE_AI_LATENCY_BUDGET_MS=12
OPENKORE_AI_REFLEX_LATENCY_BUDGET_MS=100
OPENKORE_AI_REFLEX_TRIGGER_HISTORY_PER_BOT=1000
OPENKORE_AI_SQLITE_PATH=AI_sidecar/data/sidecar.sqlite
OPENKORE_AI_SQLITE_BUSY_TIMEOUT_MS=300
OPENKORE_AI_PERSISTENCE_SNAPSHOT_HISTORY_PER_BOT=5000
OPENKORE_AI_PERSISTENCE_AUDIT_HISTORY=50000
OPENKORE_AI_MEMORY_BACKEND=sqlite
OPENKORE_AI_MEMORY_OPENMEMORY_MODE=local
OPENKORE_AI_MEMORY_OPENMEMORY_PATH=AI_sidecar/data/openmemory.sqlite
OPENKORE_AI_MEMORY_EMBEDDING_DIMENSIONS=384
OPENKORE_AI_MEMORY_SEMANTIC_CANDIDATES=500
OPENKORE_AI_MEMORY_DEFAULT_SEARCH_LIMIT=5
OPENKORE_AI_PROVIDER_OLLAMA_ENABLED=1
OPENKORE_AI_PROVIDER_OLLAMA_BASE_URL=http://127.0.0.1:11434
OPENKORE_AI_PROVIDER_OLLAMA_DEFAULT_MODEL=qwen3.6:35b-a3b-q4_K_M
OPENKORE_AI_PROVIDER_OLLAMA_TACTICAL_MODEL=qwen3.6:35b-a3b-q4_K_M
OPENKORE_AI_PROVIDER_OLLAMA_STRATEGIC_MODEL=qwen3.6:35b-a3b-q4_K_M
OPENKORE_AI_PROVIDER_OLLAMA_REFLECTION_MODEL=qwen3.6:35b-a3b-q4_K_M
OPENKORE_AI_PROVIDER_OLLAMA_EMBEDDING_MODEL=qwen3-embedding:8b
OPENKORE_AI_PROVIDER_DEEPSEEK_ENABLED=1
OPENKORE_AI_PROVIDER_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
OPENKORE_AI_PROVIDER_DEEPSEEK_API_KEY=
OPENKORE_AI_PROVIDER_DEEPSEEK_DEFAULT_MODEL=deepseek-chat
OPENKORE_AI_PROVIDER_DEEPSEEK_TACTICAL_MODEL=deepseek-chat
OPENKORE_AI_PROVIDER_DEEPSEEK_STRATEGIC_MODEL=deepseek-chat
OPENKORE_AI_PROVIDER_DEEPSEEK_REFLECTION_MODEL=deepseek-chat
OPENKORE_AI_CREWAI_ENABLED=1
OPENKORE_AI_FLEET_CENTRAL_ENABLED=1
OPENKORE_AI_FLEET_CENTRAL_BASE_URL=https://api-v3.openkore-ai.com
OPENKORE_AI_FLEET_REQUEST_TIMEOUT_SECONDS=8
