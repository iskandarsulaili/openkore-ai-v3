OPENKORE_AI_APP_NAME=openkore-ai-sidecar
OPENKORE_AI_ENV=development
OPENKORE_AI_HOST=127.0.0.1
OPENKORE_AI_PORT=18081
OPENKORE_AI_LOG_LEVEL=INFO
OPENKORE_AI_LOG_JSON=1
OPENKORE_AI_ENABLE_DOCS=1
OPENKORE_AI_CONTRACT_VERSION=v1
OPENKORE_AI_ACTION_DEFAULT_TTL_SECONDS=30
OPENKORE_AI_ACTION_MAX_QUEUE_PER_BOT=128
OPENKORE_AI_SNAPSHOT_CACHE_TTL_SECONDS=120
OPENKORE_AI_TELEMETRY_MAX_PER_BOT=500
OPENKORE_AI_LATENCY_BUDGET_MS=12

