      "max_price_zeny": 0,
      "execution_mode": "macro",
      "signal_requirements": {
        "mercenary_homunculus_intent": true,
        "companion_available": true,
        "in_combat": false
      },
      "macro_bundle": {
        "macros": [
          {
            "name": "crew_wave_a1_merc_homu_support",
            "lines": [
              "do conf attackAuto 2",
              "do conf route_randomWalk 1",
              "do conf route_step 12",
              "do conf itemsTakeAuto 2",
              "do conf itemsGatherAuto 1",
              "do conf teleportAuto_minAggressives 4",
