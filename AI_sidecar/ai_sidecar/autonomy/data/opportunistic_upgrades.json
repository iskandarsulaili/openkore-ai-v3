{
  "version": "stage4-opportunistic-upgrades-v2",
  "market_source_allowlist": ["npc_shop", "market", "player_vendor"],
  "rules": [
    {
      "rule_id": "novice_weapon_sword_2_to_3",
      "enabled": true,
      "job_names": ["Novice"],
      "slot": "weapon",
      "current_item_ids": ["sword_2"],
      "candidate_item_id": "sword_3",
      "candidate_item_name": "Sword [3]",
      "required_base_level": 8,
      "score_current": 20,
      "score_candidate": 32,
      "max_price_zeny": 6000,
      "execution_mode": "direct",
      "direct_command": "ai auto",
      "direct_conflict_key": "opportunistic.weapon_upgrade",
      "direct_preconditions": ["navigation.ready", "inventory.can_equip"],
      "notes": [
        "stage4-safe-direct: use bridge-safe ai auto posture after deterministic purchase evidence",
        "explicit buy/equip roots remain intentionally unsupported in bridge-safe direct mode"
      ]
    },
    {
      "rule_id": "swordman_weight_relief_profile",
      "enabled": true,
      "job_names": ["Swordman", "Swordsman"],
      "slot": "weapon",
      "current_item_ids": ["sword_1", "sword_2", "sword_3"],
      "candidate_item_id": "sword_3",
      "candidate_item_name": "Sword [3]",
      "required_base_level": 22,
      "score_current": 26,
      "score_candidate": 30,
      "max_price_zeny": 12000,
      "execution_mode": "config",
      "control_plan": {
        "artifact_type": "config",
        "name": "config.txt",
        "target_path": "control/config.txt",
        "desired": {
          "aiSidecar_enable": "1",
          "aiSidecar_profile": "combat_weight_relief",
          "itemsMaxWeight_sellOrStore": "50",
          "itemsTakeAuto": "2",
          "itemsGatherAuto": "1",
          "route_randomWalk": "1",
          "attackAuto": "2",
          "teleportAuto_minAggressives": "4"
        },
        "source": "crewai"
      },
      "notes": [
        "stage4-safe-config: deterministic control plan through protected control domain",
        "materially tunes inventory pressure relief, engagement posture, and anti-overpull thresholds",
        "no raw equip command emission"
      ]
    },
    {
      "rule_id": "mage_macro_refresh_upgrade_posture",
      "enabled": true,
      "job_names": ["Mage"],
      "slot": "weapon",
      "current_item_ids": ["rod_2"],
      "candidate_item_id": "rod_3",
      "candidate_item_name": "Rod [3]",
      "required_base_level": 26,
      "score_current": 21,
      "score_candidate": 29,
      "max_price_zeny": 14000,
      "execution_mode": "macro",
      "macro_bundle": {
        "macros": [
          {
            "name": "crew_stage4_upgrade_posture",
            "lines": [
              "do conf route_randomWalk 1",
              "do conf route_step 15",
              "do conf attackAuto 2",
              "do conf teleportAuto_hp 30",
              "do conf teleportAuto_minAggressives 3",
              "do conf itemsTakeAuto 2",
              "do conf itemsGatherAuto 1",
              "do conf itemsMaxWeight_sellOrStore 50",
              "call crew_stage4_recovery_cycle",
              "do ai clear",
              "do ai on"
            ]
          }
        ],
        "event_macros": [
          {
            "name": "crew_stage4_recovery_cycle",
            "lines": [
              "do conf route_teleport 1",
              "do conf teleportAuto_sp 8",
              "do conf lockMap none",
              "do conf route_randomWalk 1"
            ]
          },
          {
            "name": "crew_stage4_inventory_relief",
            "lines": [
              "do conf itemsMaxWeight_sellOrStore 48",
              "do conf itemsTakeAuto 1",
              "do conf itemsGatherAuto 0",
              "do conf storageAuto 1",
              "do ai clear",
              "do ai on"
            ]
          }
        ],
        "automacros": [
          {
            "name": "on_crew_stage4_upgrade_posture",
            "conditions": ["OnCharLogIn"],
            "call": "crew_stage4_upgrade_posture",
            "parameters": {
              "source": "stage4"
            }
          }
        ],
        "enqueue_reload": true,
        "reload_conflict_key": "macro_reload"
      },
      "notes": [
        "stage4-safe-macro: macro publication and reload only through existing safe path",
        "materially expands recovery, mobility refresh, and inventory-pressure handling payloads",
        "does not widen command roots"
      ]
    },
    {
