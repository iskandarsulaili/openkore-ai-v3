      "execution_mode": "direct",
      "direct_command": "ai auto",
      "direct_conflict_key": "opportunistic.card_gear_farm",
      "direct_preconditions": ["encounter.targets_present", "inventory.not_overweight"],
      "signal_requirements": {
        "card_gear_farming_intent": true,
        "in_combat": false,
        "nearby_hostiles_gte": 1,
        "inventory_pressure": false,
        "market_listing_count_gte": 1
      },
      "notes": [
        "wave-a1 card/gear farming posture remains in safe ai auto command lane",
        "requires intent plus encounter and inventory pressure checks"
      ]
    },
