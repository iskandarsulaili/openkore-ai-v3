# Runtime launcher configuration for start/stop/status scripts.
# Copy to: ai-sidecar-launcher.env and adjust as needed.

# Sidecar endpoint used for health checks and control file synchronization.
SIDECAR_HOST=127.0.0.1
SIDECAR_PORT=18081
SIDECAR_HEALTH_PATH=/v1/health/live
SIDECAR_START_TIMEOUT_SECONDS=45

# Extra OpenKore CLI args (space-delimited).
# Example: OPENKORE_ARGS=--interface=Console --config=config.txt
OPENKORE_ARGS=

# Optional custom log targets (relative to repository root unless absolute).
SIDECAR_LOG_FILE=.ai-sidecar-runtime/logs/sidecar.log
OPENKORE_LOG_FILE=.ai-sidecar-runtime/logs/openkore.log
